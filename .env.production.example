# ══════════════════════════════════════════════════
# ORKESTRIA - Configuracao de Producao
# IMPORTANTE: Gere valores unicos antes de usar!
# ══════════════════════════════════════════════════

# ── Database ──
# Substitua por credenciais unicas do seu RDS/PostgreSQL
DATABASE_URL=postgresql://orkestria_user:GERAR_SENHA_FORTE_AQUI@seu-host-rds:5432/orkestria

# ── Auth (OBRIGATORIO: gerar chaves unicas) ──
# Gere com: openssl rand -hex 64
JWT_SECRET=GERAR_COM_openssl_rand_hex_64
JWT_REFRESH_SECRET=GERAR_COM_openssl_rand_hex_64

# ── Redis ──
REDIS_HOST=seu-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=GERAR_SENHA_FORTE

# ── S3 (AWS ou MinIO em producao) ──
S3_BUCKET=orkestria-files
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=GERAR_IAM_KEY
AWS_SECRET_ACCESS_KEY=GERAR_IAM_SECRET

# ── App ──
PORT=4000
NODE_ENV=production
CORS_ORIGINS=https://app.seudominio.com.br
ENABLE_SWAGGER=false

# ── Frontend ──
NEXT_PUBLIC_API_URL=https://api.seudominio.com.br/api

# ── Asaas (Pagamento) ──
# Sandbox: https://sandbox.asaas.com/api/v3
# Produção: https://api.asaas.com/api/v3
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=SUA_CHAVE_API_ASAAS

# Nome do container PostgreSQL (para backup)
PG_CONTAINER=orkestria-postgres
