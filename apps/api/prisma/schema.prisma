// Orkestria — Schema Prisma
// PostgreSQL 16 | Prisma 7.x

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum RoleType {
  SUPER_ADMIN
  ADMIN
  STRATEGIST
  COPYWRITER
  TRAFFIC_MANAGER
  SOCIAL_MEDIA
  DESIGNER
  CLIENT
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum StageType {
  BACKLOG
  PLANNING
  PRODUCTION
  REVIEW
  APPROVAL
  COMPLETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum ApprovalType {
  INTERNAL
  CLIENT
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  TASK_OVERDUE
  COMMENT_ADDED
  COMMENT_MENTION
  APPROVAL_REQUESTED
  APPROVAL_RESOLVED
  FILE_SHARED
  PROJECT_UPDATED
  STAGE_CHANGED
  DEADLINE_APPROACHING
  FEEDBACK_RECEIVED
  SYSTEM
}

enum FileVisibility {
  INTERNAL
  CLIENT_SHARED
}

enum AutomationTrigger {
  PROJECT_CREATED
  STAGE_CHANGED
  TASK_CREATED
  TASK_COMPLETED
  TASK_OVERDUE
  DEADLINE_APPROACHING
  FILE_UPLOADED
  APPROVAL_SUBMITTED
  APPROVAL_APPROVED
  APPROVAL_REJECTED
  PROJECT_COMPLETED
}

enum AutomationActionType {
  CREATE_TASK
  CREATE_CHECKLIST
  SEND_NOTIFICATION
  SEND_EMAIL
  CHANGE_STATUS
  ADVANCE_STAGE
  ASSIGN_USER
  SHARE_WITH_CLIENT
  WEBHOOK
}

enum CommentVisibility {
  INTERNAL
  CLIENT_VISIBLE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  UPLOAD
  DOWNLOAD
  SHARE
  PASSWORD_CHANGE
  ROLE_ASSIGNED
  ROLE_REMOVED
  USER_DELETED
  FILE_DELETED
  APPROVAL_RESOLVED
  PORTAL_ACCESS_CHANGED
}

// ============================================================
// AUTH & USERS
// ============================================================

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  plan        TenantPlan @default(STARTER)
  status      TenantStatus @default(TRIAL)
  maxUsers    Int      @default(3) @map("max_users")
  maxProjects Int      @default(5) @map("max_projects")
  maxStorageMB Int     @default(2048) @map("max_storage_mb")
  trialEndsAt DateTime? @map("trial_ends_at")
  asaasCustomerId String? @map("asaas_customer_id")
  asaasSubscriptionId String? @map("asaas_subscription_id")
  ownerEmail  String   @map("owner_email")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  projects    Project[]
  clients     Client[]

  @@map("tenants")
}

enum TenantPlan {
  STARTER
  PRO
  AGENCY
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

model User {
  id              String    @id @default(cuid())
  tenantId        String?   @map("tenant_id")
  email           String    @unique
  passwordHash    String    @map("password_hash")
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  avatarUrl       String?   @map("avatar_url")
  phone           String?
  isActive        Boolean   @default(true) @map("is_active")
  mfaEnabled      Boolean   @default(false) @map("mfa_enabled")
  mfaSecret       String?   @map("mfa_secret")
  lastLoginAt     DateTime? @map("last_login_at")
  passwordResetToken   String?   @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  roles            UserRole[]
  clientUsers      ClientUser[]
  projectMembers   ProjectMember[]
  assignedTasks    Task[]           @relation("TaskAssignee")
  createdTasks     Task[]           @relation("TaskCreator")
  comments         TaskComment[]
  approvalsSent    Approval[]       @relation("ApprovalRequester")
  approvalsResolved Approval[]      @relation("ApprovalResolver")
  notifications    Notification[]
  createdTemplates ProjectTemplate[] @relation("TemplateCreator")
  uploadedFiles    File[]
  auditLogs        AuditLog[]
  refreshTokens    RefreshToken[]
  timeEntries      TimeEntry[]
  tenant           Tenant?   @relation(fields: [tenantId], references: [id])

  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  name        RoleType @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  userRoles   UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Permission {
  id       String @id @default(cuid())
  resource String
  action   String

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ============================================================
// CLIENTS
// ============================================================

model Client {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")
  name        String
  companyName String?  @map("company_name")
  email       String?
  phone       String?
  website     String?
  document    String?  @map("document") // CPF or CNPJ
  documentType String? @map("document_type") // PF or PJ
  address     String?
  city        String?
  state       String?
  zipCode     String?  @map("zip_code")
  country     String?  @default("Brasil")
  contractUrl String?  @map("contract_url")
  logoUrl     String?  @map("logo_url")
  notes       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  clientUsers ClientUser[]
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  projects    Project[]

  @@map("clients")
}

model ClientUser {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  userId    String   @map("user_id")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
  @@map("client_users")
}

// ============================================================
// PROJECTS
// ============================================================

model Project {
  id            String          @id @default(cuid())
  tenantId      String?         @map("tenant_id")
  name          String
  description   String?
  briefing      String?         @db.Text
  objective     String?         @db.Text
  channels      String[]
  priority      ProjectPriority @default(MEDIUM)
  status        ProjectStatus   @default(DRAFT)
  budget        Decimal?        @db.Decimal(12, 2)
  currency      String          @default("BRL")
  startDate     DateTime?       @map("start_date")
  endDate       DateTime?       @map("end_date")
  completedAt   DateTime?       @map("completed_at")
  progress      Int             @default(0)
  clientId      String?         @map("client_id")
  createdById   String          @map("created_by_id")
  isDeleted     Boolean         @default(false) @map("is_deleted")
  metadata      Json?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  client        Client?         @relation(fields: [clientId], references: [id])
  tenant        Tenant?         @relation(fields: [tenantId], references: [id])
  members       ProjectMember[]
  stages        ProjectStage[]
  tasks         Task[]
  files         File[]
  automations   Automation[]

  @@index([clientId])
  @@index([status])
  @@index([createdById])
  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  roleInProject String? @map("role_in_project")
  joinedAt  DateTime @default(now()) @map("joined_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model ProjectStage {
  id          String    @id @default(cuid())
  projectId   String    @map("project_id")
  type        StageType
  name        String
  order       Int
  isActive    Boolean   @default(false) @map("is_active")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, type])
  @@index([projectId, order])
  @@map("project_stages")
}

// ============================================================
// TASKS
// ============================================================

model Task {
  id             String       @id @default(cuid())
  projectId      String       @map("project_id")
  stageId        String?      @map("stage_id")
  parentTaskId   String?      @map("parent_task_id")
  title          String
  description    String?      @db.Text
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  assigneeId     String?      @map("assignee_id")
  createdById    String       @map("created_by_id")
  startDate      DateTime?    @map("start_date")
  dueDate        DateTime?    @map("due_date")
  completedAt    DateTime?    @map("completed_at")
  estimatedHours Decimal?     @map("estimated_hours") @db.Decimal(6, 2)
  order          Int          @default(0)
  isDeleted      Boolean      @default(false) @map("is_deleted")
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage            ProjectStage?     @relation(fields: [stageId], references: [id])
  parentTask       Task?             @relation("SubTasks", fields: [parentTaskId], references: [id])
  subtasks         Task[]            @relation("SubTasks")
  assignee         User?             @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy        User              @relation("TaskCreator", fields: [createdById], references: [id])
  comments         TaskComment[]
  checklists       TaskChecklist[]
  files            File[]
  approvals        Approval[]
  timeEntries      TimeEntry[]
  dependenciesFrom TaskDependency[]  @relation("DependencyFrom")
  dependenciesTo   TaskDependency[]  @relation("DependencyTo")

  @@index([projectId, status])
  @@index([assigneeId])
  @@index([stageId])
  @@index([parentTaskId])
  @@index([dueDate])
  @@map("tasks")
}

model TaskDependency {
  id              String @id @default(cuid())
  taskId          String @map("task_id")
  dependsOnTaskId String @map("depends_on_task_id")

  task          Task @relation("DependencyFrom", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask Task @relation("DependencyTo", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@map("task_dependencies")
}

model TaskChecklist {
  id        String          @id @default(cuid())
  taskId    String          @map("task_id")
  title     String
  order     Int             @default(0)
  createdAt DateTime        @default(now()) @map("created_at")

  task  Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  items ChecklistItem[]

  @@map("task_checklists")
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String    @map("checklist_id")
  text        String
  isCompleted Boolean   @default(false) @map("is_completed")
  order       Int       @default(0)
  completedAt DateTime? @map("completed_at")

  checklist TaskChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

model TimeEntry {
  id          String   @id @default(cuid())
  taskId      String   @map("task_id")
  userId      String   @map("user_id")
  description String?
  minutes     Int
  date        DateTime @db.Date
  createdAt   DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId, date])
  @@map("time_entries")
}

// ============================================================
// COMMENTS
// ============================================================

model TaskComment {
  id         String            @id @default(cuid())
  taskId     String            @map("task_id")
  userId     String            @map("user_id")
  content    String            @db.Text
  visibility CommentVisibility @default(INTERNAL)
  parentId   String?           @map("parent_id")
  isEdited   Boolean           @default(false) @map("is_edited")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  task     Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id])
  parent   TaskComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  TaskComment[] @relation("CommentReplies")
  mentions CommentMention[]

  @@index([taskId, createdAt])
  @@map("task_comments")
}

model CommentMention {
  id        String @id @default(cuid())
  commentId String @map("comment_id")
  userId    String @map("user_id")

  comment TaskComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_mentions")
}

// ============================================================
// FILES
// ============================================================

model File {
  id           String         @id @default(cuid())
  projectId    String?        @map("project_id")
  taskId       String?        @map("task_id")
  uploadedById String         @map("uploaded_by_id")
  fileName     String         @map("file_name")
  originalName String         @map("original_name")
  mimeType     String         @map("mime_type")
  sizeBytes    BigInt         @map("size_bytes")
  s3Key        String         @map("s3_key")
  s3Bucket     String         @map("s3_bucket")
  version      Int            @default(1)
  parentFileId String?        @map("parent_file_id")
  visibility   FileVisibility @default(INTERNAL)
  description  String?
  isDeleted    Boolean        @default(false) @map("is_deleted")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  project    Project?   @relation(fields: [projectId], references: [id])
  task       Task?      @relation(fields: [taskId], references: [id])
  uploadedBy User       @relation(fields: [uploadedById], references: [id])
  parentFile File?      @relation("FileVersions", fields: [parentFileId], references: [id])
  versions   File[]     @relation("FileVersions")
  approvals  Approval[]

  @@index([projectId])
  @@index([taskId])
  @@index([visibility])
  @@map("files")
}

// ============================================================
// APPROVALS
// ============================================================

model Approval {
  id            String         @id @default(cuid())
  taskId        String?        @map("task_id")
  fileId        String?        @map("file_id")
  type          ApprovalType   @default(INTERNAL)
  status        ApprovalStatus @default(PENDING)
  requestedById String         @map("requested_by_id")
  resolvedById  String?        @map("resolved_by_id")
  title         String
  description   String?        @db.Text
  feedback      String?        @db.Text
  resolvedAt    DateTime?      @map("resolved_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  task        Task?  @relation(fields: [taskId], references: [id])
  file        File?  @relation(fields: [fileId], references: [id])
  requestedBy User   @relation("ApprovalRequester", fields: [requestedById], references: [id])
  resolvedBy  User?  @relation("ApprovalResolver", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([type, status])
  @@index([requestedById])
  @@map("approvals")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================================
// AUTOMATIONS
// ============================================================

model ProjectTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?  // ex: "Lançamento", "Gestão de Redes", "Campanha"
  stages      Json     @default("[]") // array of stage names
  isActive    Boolean  @default(true) @map("is_active")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy   User     @relation("TemplateCreator", fields: [createdById], references: [id])
  tasks       TaskTemplate[]

  @@map("project_templates")
}

model TaskTemplate {
  id                String   @id @default(cuid())
  projectTemplateId String   @map("project_template_id")
  title             String
  description       String?  @db.Text
  stage             String   // name of the stage this task belongs to (ex: "Planejamento")
  priority          TaskPriority @default(MEDIUM)
  assigneeRole      String?  @map("assignee_role") // role name to auto-assign (ex: "COPYWRITER")
  dueDaysOffset     Int      @default(0) @map("due_days_offset") // days after project start
  dependsOnIndex    Int?     @map("depends_on_index") // index of task that must be done first
  order             Int      @default(0)
  estimatedHours    Decimal? @map("estimated_hours") @db.Decimal(6, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  projectTemplate   ProjectTemplate @relation(fields: [projectTemplateId], references: [id], onDelete: Cascade)

  @@map("task_templates")
}

model Automation {
  id          String            @id @default(cuid())
  projectId   String?           @map("project_id")
  name        String
  description String?
  trigger     AutomationTrigger
  conditions  Json?
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  project Project?          @relation(fields: [projectId], references: [id])
  actions AutomationAction[]

  @@index([trigger, isActive])
  @@map("automations")
}

model AutomationAction {
  id           String               @id @default(cuid())
  automationId String               @map("automation_id")
  type         AutomationActionType
  config       Json
  order        Int                  @default(0)

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@map("automation_actions")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?     @map("user_id")
  action     AuditAction
  resource   String
  resourceId String?     @map("resource_id")
  details    Json?
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}
