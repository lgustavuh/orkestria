# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orkestria

# ── Auth ──
JWT_SECRET=orkestria-dev-jwt-secret-change-in-production-64chars-minimum-ok
JWT_REFRESH_SECRET=orkestria-dev-refresh-secret-change-in-production-too-64c

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── S3 / MinIO ──
S3_BUCKET=orkestria-files
S3_ENDPOINT=http://localhost:9000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ── App ──
PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:4000/api
